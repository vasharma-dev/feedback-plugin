# Copy this file to `.env` before running the backend:  cp .env.example .env
#
# SQLite for zero-setup local dev — it's just a file, no DB server to run.
# For production, change provider to "postgresql" in prisma/schema.prisma and set this to a
# Postgres URL, e.g. postgresql://user:pass@host:5432/feedback
DATABASE_URL="file:./dev.db"
PORT=4000

# ---- Optional production integrations (leave blank to use the simulated fallbacks) ----
# Public base URL of this backend; used for OAuth + Stripe redirect URLs.
APP_URL="http://localhost:4000"

# Real "Sign in with Google" — create an OAuth 2.0 Client (Web) in Google Cloud Console,
# add http://localhost:4000/auth/google/callback as an authorized redirect URI, then paste:
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Real Stripe Checkout for buying token packs — use your TEST-mode secret key (sk_test_...):
STRIPE_SECRET_KEY=""
