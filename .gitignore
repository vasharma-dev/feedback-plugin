.env
.env.*
!.env.example

# Databases (SQLite prototype store)
*.db
*.db-journal
*.sqlite

# Logs
*.log
npm-debug.log*

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
