{
  "name": "@jicama/feedback-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Hosted backend for the jicama.tech feedback plugin (ingest + admin API).",
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "predev": "prisma generate && prisma db push --skip-generate",
    "dev": "tsx watch src/index.ts",
    "prestart": "prisma generate && prisma db push --skip-generate",
    "start": "tsx src/index.ts",
    "smoke": "node scripts/smoke.mjs",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.17.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "nanoid": "^5.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "prisma": "^5.17.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
