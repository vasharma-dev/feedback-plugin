// Data model — mirrors DESIGN.md §6.
//
// Using SQLite so the prototype runs with zero setup (the DB is a single file).
// To go to Postgres: change `provider = "postgresql"` below and point DATABASE_URL at it.
// SQLite has no enum / JSON / array types, so those fields are String (JSON-encoded);
// on Postgres you'd switch them to enums and Json columns.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id
  name      String
  website   String? // the org's site, captured at registration
  plan      String   @default("free") // free | pro | enterprise
  createdAt DateTime @default(now())

  // ---- Billing (prototype: simulated "test mode", Stripe-ready) ----
  // Tokens are the currency: 1 accepted feedback = 1 token. Orgs buy packs to top up.
  tokenBalance       Int       @default(100) // starter grant; topped up by buying packs
  billingEmail       String?
  subStatus          String    @default("active") // active | past_due | canceled | trialing
  currentPeriodStart DateTime  @default(now()) // start of the usage window (for "used this period")
  currentPeriodEnd   DateTime? // informational; shown in the dashboard
  // Card "on file" — in real Stripe we'd only ever store these display-safe bits.
  cardBrand    String?
  cardLast4    String?
  cardExpMonth Int?
  cardExpYear  Int?

  projects Project[]
  apiKeys  ApiKey[]
  feedback Feedback[]
  payments Payment[]
  users    User[]
}

// A human account (the customer/admin). Created on first "Sign in with Google";
// linked to a Tenant once they complete onboarding. Auth in the prototype is a
// simulated Google login — swap mockGoogleProfile() for a real OAuth callback later.
model User {
  id        String   @id
  email     String   @unique
  name      String?
  avatarUrl String?
  googleId  String?  @unique // the Google "sub"; mocked in the prototype
  tenantId  String? // null until onboarding creates/links an org
  role      String   @default("owner") // owner (full access) | member (employee, RBAC-limited)
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  sessions  Session[]

  @@index([tenantId])
}

// Opaque session token stored in an httpOnly cookie. One row per active login.
model Session {
  id        String   @id // the session token itself (random, unguessable)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
}

model Project {
  id             String     @id
  tenantId       String
  name           String
  // ---- Widget theming / branding ----
  themeColor     String     @default("#6C2BD9")
  themePosition  String     @default("bottom-right")
  launcherText   String     @default("Feedback") // text on the floating button
  launcherIcon   String     @default("💬") // emoji on the button + modal
  headerTitle    String     @default("Share your feedback")
  headerSubtitle String     @default("We read every message — thank you for helping us improve.")
  dialogBg       String     @default("#ffffff") // background color of the feedback dialog
  hideBranding   Boolean    @default(false) // white-label: drop "Powered by jicama"
  // Human-friendly feedback reference IDs, e.g. prefix "jicamabug" → jicamabug01, jicamabug02…
  feedbackPrefix String     @default("") // empty = no custom reference
  feedbackSeq    Int        @default(0) // running counter, incremented per accepted feedback
  allowedOrigins String     @default("[\"*\"]") // JSON array of origins
  tenant         Tenant     @relation(fields: [tenantId], references: [id])
  apiKeys        ApiKey[]
  feedback       Feedback[]

  @@index([tenantId])
}

model ApiKey {
  id        String   @id
  tenantId  String
  projectId String? // public keys belong to a project; secret keys are tenant-wide
  keyHash   String?  @unique // sha256(key) — the lookup. Secrets are stored ONLY as this hash.
  key       String? // plaintext kept only for PUBLIC keys (they're embedded in HTML anyway); null for secrets
  kind      String // public | secret
  active    Boolean  @default(true)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])
}

model Feedback {
  id          String       @id
  ref         String? // human-friendly reference, e.g. "jicamabug01" (per the project's prefix)
  groupId     String? // AI grouping: the canonical feedback id this duplicates (null = canonical)
  summary     String? // AI one-line context for the issue
  module      String? // AI-derived area/module
  projectId   String
  tenantId    String
  type        String // bug | idea | praise | question
  message     String
  rating      Int? // 1..5
  status      String       @default("new") // new | in_progress | done | wont_do
  assigneeId  String? // user id of the team member working on it
  endUser     String? // JSON: { id?, email? }
  metadata    String       @default("{}") // JSON: url/browser/os/device/...
  createdAt   DateTime     @default(now())
  project     Project      @relation(fields: [projectId], references: [id])
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  attachments Attachment[]

  @@index([tenantId, status])
  @@index([tenantId, type])
}

// A billing transaction / invoice line. In the prototype these are simulated charges;
// with real Stripe each row would mirror a Stripe Invoice / PaymentIntent.
model Payment {
  id          String   @id
  tenantId    String
  extId       String?  @unique // external payment id (Stripe Checkout session) — idempotency guard
  plan        String // plan purchased
  amountCents Int
  currency    String   @default("usd")
  status      String   @default("paid") // paid | failed | refunded
  cardBrand   String?
  cardLast4   String?
  description String
  periodStart DateTime @default(now())
  periodEnd   DateTime?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// Activity timeline for a feedback item — who did what, when (created/status/assigned/comment).
model FeedbackEvent {
  id         String   @id
  feedbackId String
  tenantId   String
  actorId    String? // user id (null = via API/system)
  actorName  String // display name captured at the time
  kind       String // created | status | assigned | unassigned | comment
  detail     String   @default("")
  createdAt  DateTime @default(now())

  @@index([feedbackId])
}

model Attachment {
  id         String   @id
  feedbackId String
  filename   String
  mime       String
  dataUrl    String // prototype inlines as data URL; production stores an S3/R2 URL
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
}

// Token packs the dashboard offers. Pricing lives in the DB (seeded from defaults) so the
// platform owner can change it from the Super Admin panel — live for every tenant.
model TokenPack {
  id         String  @id // "starter" | "growth" | "scale"
  name       String
  tokens     Int
  priceCents Int
  tagline    String
  popular    Boolean @default(false)
  sortOrder  Int     @default(0)
}

// The platform owner (you). Separate from tenant Users — logs in with email + password.
model SuperAdmin {
  id           String   @id
  email        String   @unique
  passwordHash String // scrypt: "salt:hash"
  createdAt    DateTime @default(now())
}

model SuperAdminSession {
  id           String   @id // opaque token (httpOnly cookie)
  superAdminId String
  createdAt    DateTime @default(now())
  expiresAt    DateTime
}

// Platform-wide settings the Super Admin edits at runtime (e.g. the Stripe secret key), so
// payments can be configured from the panel instead of only an env var. Simple key/value.
model Setting {
  key   String @id
  value String
}
